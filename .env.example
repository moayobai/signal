# ─── AI Provider ────────────────────────────────────────────────
# Choose "claude" (default) or "openrouter"
AI_PROVIDER=claude

# Anthropic API key (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (required when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...

# Model overrides (optional — defaults shown)
LIVE_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-sonnet-4-6

# ─── Deepgram ────────────────────────────────────────────────────
# Real-time speech-to-text
DEEPGRAM_API_KEY=...
# Model: nova-3 (default, best accuracy), nova-2, base, enhanced
DEEPGRAM_MODEL=nova-3

# ─── OctaMem ─────────────────────────────────────────────────────
# Persistent prospect memory (https://octamem.com)
OCTAMEM_API_KEY=...
# Override the OctaMem base URL (optional)
# OCTAMEM_BASE_URL=https://api.octamem.com

# ─── Hume AI ─────────────────────────────────────────────────────
# Real-time facial emotion analysis from video frames (https://hume.ai)
# Optional — leave blank to disable. Audio-only mode remains fully functional.
HUME_API_KEY=...

# ─── Server ──────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# SQLite database path
# Production (Fly.io volume): /data/signal.db
# Local dev:                  ./signal.db
DATABASE_URL=./signal.db
