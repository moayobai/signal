# ─── AI Provider ────────────────────────────────────────────────
# Choose "claude" (default) or "openrouter"
AI_PROVIDER=claude

# Anthropic API key (required when AI_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key (required when AI_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-...

# Model overrides (optional — defaults shown)
LIVE_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-sonnet-4-6

# Post-call scoring framework — 'MEDDIC' | 'SPICED' | 'BANT'
SCORING_FRAMEWORK=MEDDIC

# ─── Deepgram ────────────────────────────────────────────────────
# Real-time speech-to-text
DEEPGRAM_API_KEY=...
# Model: nova-3 (default, best accuracy), nova-2, base, enhanced
DEEPGRAM_MODEL=nova-3

# ─── OctaMem ─────────────────────────────────────────────────────
# Persistent prospect memory (https://octamem.com)
OCTAMEM_API_KEY=...
# Override the OctaMem base URL (optional)
# OCTAMEM_BASE_URL=https://api.octamem.com

# ─── Hume AI ─────────────────────────────────────────────────────
# Real-time facial emotion analysis from video frames (https://hume.ai)
# Optional — leave blank to disable. Audio-only mode remains fully functional.
HUME_API_KEY=...

# ─── Voyage AI ───────────────────────────────────────────────────
# Embeddings (voyage-3-lite, 256-dim) for semantic transcript search.
# Powers the /search dashboard page — ask in plain English, get meaning-based
# matches across every call. Get a key at https://voyageai.com.
# Optional — leave as placeholder to disable the feature.
VOYAGE_API_KEY=your-voyage-key-here

# ─── Slack ───────────────────────────────────────────────────────
# Post-call summary auto-posts to this channel.
# Create an incoming webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# ─── HubSpot ─────────────────────────────────────────────────────
# Sync contacts and log calls as engagements.
# Create a Private App in HubSpot admin → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=your-hubspot-key-here

# ─── Gmail ───────────────────────────────────────────────────────
# Writes in the user's sent-mail voice for follow-up drafts.
# 1. Create OAuth client in Google Cloud console (type: web)
# 2. Run `node scripts/google-oauth.mjs` to get a refresh token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── Google Calendar ─────────────────────────────────────────────
# Pre-call meeting detection (https://console.cloud.google.com)
# Scope: https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN_CALENDAR=

# ─── Outlook / Microsoft 365 Calendar ────────────────────────────
# Pre-call meeting detection (https://portal.azure.com → App registrations)
# Scope: Calendars.Read
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=
OUTLOOK_TENANT_ID=common

# ─── Server ──────────────────────────────────────────────────────
# Required unless SIGNAL_AUTH_DISABLED=true. Use the same token when building
# the extension so it can authenticate API and WebSocket requests.
SIGNAL_AUTH_TOKEN=replace-with-openssl-rand-base64-32
SIGNAL_AUTH_DISABLED=false
SIGNAL_RATE_LIMIT_MAX=120
SIGNAL_RATE_LIMIT_WINDOW=1 minute
SIGNAL_BODY_LIMIT_BYTES=1048576
SIGNAL_WS_MAX_MESSAGE_BYTES=1048576
SIGNAL_DB_BACKUP_DIR=
SIGNAL_DB_BACKUP_BEFORE_MIGRATIONS=true

# Public URL of the deployed dashboard (used when Slack links back to a call)
PUBLIC_BASE_URL=

PORT=8080
NODE_ENV=development

# SQLite database path
# Production (Fly.io volume): /data/signal.db
# Local dev:                  ./signal.db
DATABASE_URL=./signal.db
