# AI provider — 'claude' or 'openrouter'
AI_PROVIDER=claude

# Claude direct
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenRouter alternative (OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-your-key-here

# Model overrides
LIVE_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-sonnet-4-6

# Post-call scoring framework — 'MEDDIC' | 'SPICED' | 'BANT'
SCORING_FRAMEWORK=MEDDIC

# Deepgram STT
DEEPGRAM_API_KEY=your-deepgram-key-here
# Model options: nova-3 (default, best accuracy), nova-2, base, enhanced
DEEPGRAM_MODEL=nova-3

# OctaMem semantic memory
OCTAMEM_API_KEY=your-octamem-key-here
# OCTAMEM_BASE_URL=https://api.octamem.com

# Hume AI — facial emotion analysis from video frames (https://hume.ai)
# Optional: leave blank to disable. Video capture still works for audio without this.
HUME_API_KEY=your-hume-key-here

# Voyage AI — embeddings for semantic transcript search (https://voyageai.com)
# Optional: leave as placeholder to disable the /search dashboard page.
VOYAGE_API_KEY=your-voyage-key-here

# SQLite path (Fly prod: /data/signal.db; dev: ./signal.db)
DATABASE_URL=./signal.db

# Slack — post-call summary auto-posts to this channel
# Create an incoming webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# HubSpot — sync contacts and log calls as engagements
# Create a Private App in HubSpot admin → Settings → Integrations → Private Apps
HUBSPOT_API_KEY=your-hubspot-key-here

# Gmail — writes in the user's sent-mail voice for follow-up drafts
# 1. Create OAuth client in Google Cloud console (type: web)
# 2. Run `node scripts/google-oauth.mjs` to get a refresh token
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── Google Calendar ─────────────────────────────────────────────
# Pre-call meeting detection (https://console.cloud.google.com)
# Scope: https://www.googleapis.com/auth/calendar.readonly
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN_CALENDAR=

# ─── Outlook / Microsoft 365 Calendar ────────────────────────────
# Pre-call meeting detection (https://portal.azure.com → App registrations)
# Scope: Calendars.Read
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=
OUTLOOK_TENANT_ID=common

# Public dashboard URL (used in Slack call links). Example: https://signal.example.com
PUBLIC_BASE_URL=

# Required unless SIGNAL_AUTH_DISABLED=true. Use the same token when building
# the extension so it can authenticate API and WebSocket requests.
SIGNAL_AUTH_TOKEN=replace-with-openssl-rand-base64-32
SIGNAL_AUTH_DISABLED=false
SIGNAL_RATE_LIMIT_MAX=120
SIGNAL_RATE_LIMIT_WINDOW=1 minute
SIGNAL_BODY_LIMIT_BYTES=1048576
SIGNAL_WS_MAX_MESSAGE_BYTES=1048576
SIGNAL_DB_BACKUP_DIR=
SIGNAL_DB_BACKUP_BEFORE_MIGRATIONS=true

PORT=8080
NODE_ENV=development
